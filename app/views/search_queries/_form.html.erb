<%= form_with model: search_query, class: "space-y-6" do |f| %>
  <% if search_query.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h3 class="text-sm font-medium text-red-800">
        <%= pluralize(search_query.errors.count, "error") %> prevented this query from being saved:
      </h3>
      <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
        <% search_query.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          placeholder: "Senior Software Engineer" %>
  </div>

  <div>
    <%= f.label :portal, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :portal,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          placeholder: "jobs.lever.co" %>
    <p class="mt-1 text-xs text-gray-500">ATS portal domain (e.g. jobs.lever.co, boards.greenhouse.io)</p>
  </div>

  <div>
    <%= f.label :additional_filters, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :additional_filters,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          placeholder: '-"remote in the US"' %>
    <p class="mt-1 text-xs text-gray-500">Optional extra Google search terms</p>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
